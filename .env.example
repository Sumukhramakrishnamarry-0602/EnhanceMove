# Supabase — from Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Used to build email redirect links (magic link, signup confirmation).
# Local dev: http://localhost:3000  ·  Production: https://your-domain.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional — enables the AI "Insight" box on activities (summary + next
# action). Leave unset and the app falls back to a simple rule-based
# summary with no API calls.
ANTHROPIC_API_KEY=
